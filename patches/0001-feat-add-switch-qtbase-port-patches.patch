diff --git a/src/corelib/sys/utsname.h b/src/corelib/sys/utsname.h
new file mode 100644
index 00000000..d4d3e8e4
--- /dev/null
+++ b/src/corelib/sys/utsname.h
@@ -0,0 +1,42 @@
+#ifndef QT_SWITCH_COMPAT_SYS_UTSNAME_H
+#define QT_SWITCH_COMPAT_SYS_UTSNAME_H
+
+#ifdef __SWITCH__
+
+#include <string.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+struct utsname {
+    char sysname[65];
+    char nodename[65];
+    char release[65];
+    char version[65];
+    char machine[65];
+};
+
+static inline int uname(struct utsname *buf)
+{
+    if (!buf)
+        return -1;
+
+    memset(buf, 0, sizeof(*buf));
+    strncpy(buf->sysname, "Horizon", sizeof(buf->sysname) - 1);
+    strncpy(buf->nodename, "switch", sizeof(buf->nodename) - 1);
