diff --git a/src/corelib/string.h b/src/corelib/string.h
new file mode 100644
index 00000000..8e88e86f
--- /dev/null
+++ b/src/corelib/string.h
@@ -0,0 +1,37 @@
+#ifndef QT_SWITCH_COMPAT_STRING_H
+#define QT_SWITCH_COMPAT_STRING_H
+
+#ifdef __SWITCH__
+#  include_next <string.h>
+
+#  ifdef __cplusplus
+extern "C" {
+#  endif
+
+static inline void *qt_switch_memrchr_impl(const void *s, int c, size_t n)
+{
+    const unsigned char *p = (const unsigned char *)s + n;
+    while (p != (const unsigned char *)s) {
+        --p;
+        if (*p == (unsigned char)c)
+            return (void *)p;
+    }
+    return 0;
+}
+
+#  ifndef memrchr
+static inline void *memrchr(const void *s, int c, size_t n)
+{
+    return qt_switch_memrchr_impl(s, c, n);
+}
+#  endif
+
+#  ifdef __cplusplus
+}
+#  endif
+
+#else
+#  include_next <string.h>
+#endif
+
+#endif
