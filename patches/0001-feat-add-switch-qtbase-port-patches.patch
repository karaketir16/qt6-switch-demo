diff --git a/src/plugins/platforms/switch/qnxswitchintegration.cpp b/src/plugins/platforms/switch/qnxswitchintegration.cpp
new file mode 100644
index 00000000..02ddbc92
--- /dev/null
+++ b/src/plugins/platforms/switch/qnxswitchintegration.cpp
@@ -0,0 +1,324 @@
+#include "qnxswitchintegration.h"
+
+#include "../../../gui/platform/unix/qgenericunixeventdispatcher_p.h"
+
+#include <QCoreApplication>
+#include <QGuiApplication>
+#include <QtGui/private/qguiapplication_p.h>
+#include <qpa/qplatformbackingstore.h>
+#include <qpa/qplatformnativeinterface.h>
+#include <qpa/qplatformwindow.h>
+#include <qpa/qwindowsysteminterface.h>
+
+#include <switch.h>
+
+namespace {
+
+struct SwitchRuntimeState
+{
+    bool initialized = false;
+    bool framebufferReady = false;
+    bool inputReady = false;
+    Framebuffer framebuffer {};
+    PadState pad {};
+    u64 previousButtons = 0;
+};
+
+SwitchRuntimeState &runtimeState()
+{
+    static SwitchRuntimeState state;
+    return state;
+}
+
+Qt::KeyboardModifiers switchModifiers(u64 buttons)
+{
+    Qt::KeyboardModifiers mods;
+    if (buttons & (HidNpadButton_L | HidNpadButton_R))
+        mods |= Qt::ControlModifier;
+    if (buttons & (HidNpadButton_ZL | HidNpadButton_ZR))
+        mods |= Qt::ShiftModifier;
+    return mods;
+}
+
+int switchButtonToQtKey(u64 button)
+{
+    switch (button) {
+    case HidNpadButton_A:
+        return Qt::Key_Return;
+    case HidNpadButton_B:
+        return Qt::Key_Escape;
+    case HidNpadButton_X:
+        return Qt::Key_Space;
+    case HidNpadButton_Y:
+        return Qt::Key_Backspace;
+    case HidNpadButton_Up:
+    case HidNpadButton_StickLUp:
+        return Qt::Key_Up;
+    case HidNpadButton_Down:
+    case HidNpadButton_StickLDown:
+        return Qt::Key_Down;
+    case HidNpadButton_Left:
+    case HidNpadButton_StickLLeft:
+        return Qt::Key_Left;
+    case HidNpadButton_Right:
+    case HidNpadButton_StickLRight:
+        return Qt::Key_Right;
+    case HidNpadButton_Plus:
+        return Qt::Key_Plus;
+    case HidNpadButton_Minus:
+        return Qt::Key_Minus;
+    default:
+        return 0;
+    }
+}
+
+void deliverButtonChanges(QWindow *window, u64 changedButtons, u64 buttonsDown)
+{
+    if (!window)
+        return;
+
+    static constexpr u64 mappedButtons[] = {
+        HidNpadButton_A,
+        HidNpadButton_B,
+        HidNpadButton_X,
+        HidNpadButton_Y,
+        HidNpadButton_Up,
+        HidNpadButton_Down,
+        HidNpadButton_Left,
+        HidNpadButton_Right,
+        HidNpadButton_StickLUp,
+        HidNpadButton_StickLDown,
+        HidNpadButton_StickLLeft,
+        HidNpadButton_StickLRight,
+        HidNpadButton_Plus,
+        HidNpadButton_Minus,
+    };
+
+    const Qt::KeyboardModifiers mods = switchModifiers(buttonsDown);
+    for (u64 button : mappedButtons) {
+        if (!(changedButtons & button))
+            continue;
+        const int qtKey = switchButtonToQtKey(button);
+        if (!qtKey)
+            continue;
+        const bool pressed = (buttonsDown & button) != 0;
+        QWindowSystemInterface::handleKeyEvent(window,
+                                               pressed ? QEvent::KeyPress : QEvent::KeyRelease,
+                                               qtKey,
+                                               mods);
+    }
+}
+
+bool ensureSwitchRuntime()
+{
+    auto &state = runtimeState();
+    if (state.initialized)
+        return state.framebufferReady;
+
+    state.initialized = true;
+    padConfigureInput(1, HidNpadStyleSet_NpadStandard);
+    padInitializeDefault(&state.pad);
+    state.inputReady = true;
+
+    NWindow *window = nwindowGetDefault();
+    if (!window)
+        return false;
+
+    if (R_FAILED(framebufferCreate(&state.framebuffer, window, 1280, 720, PIXEL_FORMAT_RGBA_8888, 2)))
+        return false;
+    if (R_FAILED(framebufferMakeLinear(&state.framebuffer))) {
+        framebufferClose(&state.framebuffer);
+        return false;
+    }
+
+    state.framebufferReady = true;
+    return true;
+}
+
+void shutdownSwitchRuntime()
+{
+    auto &state = runtimeState();
+    if (state.framebufferReady)
+        framebufferClose(&state.framebuffer);
+    state = {};
+}
+
+void pumpSwitchEvents(QWindow *window)
+{
+    auto &state = runtimeState();
+    if (!state.inputReady)
+        return;
+
+    padUpdate(&state.pad);
+    const u64 buttonsDown = padGetButtons(&state.pad);
+    const u64 changed = state.previousButtons ^ buttonsDown;
+    deliverButtonChanges(window, changed, buttonsDown);
+    state.previousButtons = buttonsDown;
+
+    if ((buttonsDown & HidNpadButton_Plus) || !appletMainLoop())
+        QCoreApplication::quit();
+}
+
+void presentImage(const QImage &image)
+{
+    if (!ensureSwitchRuntime())
+        return;
+
+    auto &state = runtimeState();
+    u32 stride = 0;
+    auto *dst = static_cast<uchar *>(framebufferBegin(&state.framebuffer, &stride));
+    if (!dst)
+        return;
+
+    const QImage src = image.convertToFormat(QImage::Format_RGBA8888);
+    const int copyHeight = qMin(src.height(), 720);
+    const int copyWidthBytes = qMin(src.width(), 1280) * 4;
+    for (int y = 0; y < copyHeight; ++y)
+        memcpy(dst + y * stride, src.constScanLine(y), copyWidthBytes);
+
+    framebufferEnd(&state.framebuffer);
+}
+
+} // namespace
+
+QSwitchScreen::QSwitchScreen()
+    : m_geometry(0, 0, 1280, 720)
+    , m_physicalSize(236.0, 133.0)
+{
+}
+
+QRect QSwitchScreen::geometry() const
+{
+    return m_geometry;
+}
+
+int QSwitchScreen::depth() const
+{
+    return m_depth;
+}
+
+QImage::Format QSwitchScreen::format() const
+{
+    return m_format;
+}
+
+QSizeF QSwitchScreen::physicalSize() const
+{
+    return m_physicalSize;
+}
+
+class QSwitchPlatformWindow final : public QPlatformWindow
+{
+public:
+    explicit QSwitchPlatformWindow(QWindow *window)
+        : QPlatformWindow(window)
+    {
+    }
+
+    void setGeometry(const QRect &rect) override
+    {
+        QPlatformWindow::setGeometry(rect);
+        if (window())
+            QWindowSystemInterface::handleGeometryChange(window(), rect);
+    }
+
+    void setVisible(bool visible) override
+    {
+        if (!window())
+            return;
+
+        if (visible) {
+            requestActivateWindow();
+            QWindowSystemInterface::handleExposeEvent(window(), QRegion(window()->geometry()));
+        } else {
+            QWindowSystemInterface::handleExposeEvent(window(), QRegion());
+        }
+    }
+};
+
+class QSwitchBackingStore final : public QPlatformBackingStore
+{
+public:
+    explicit QSwitchBackingStore(QWindow *window)
+        : QPlatformBackingStore(window)
+    {
+    }
+
+    QPaintDevice *paintDevice() override
+    {
+        return &m_image;
+    }
+
+    void flush(QWindow *window, const QRegion &region, const QPoint &offset) override
+    {
+        Q_UNUSED(region);
+        Q_UNUSED(offset);
+        presentImage(m_image);
+        pumpSwitchEvents(window);
+    }
+
+    void resize(const QSize &size, const QRegion &staticContents) override
+    {
+        Q_UNUSED(staticContents);
+        if (m_image.size() != size)
+            m_image = QImage(size, QImage::Format_RGBA8888);
+    }
+
+private:
+    QImage m_image;
+};
+
+QNxSwitchIntegration::QNxSwitchIntegration()
+{
+    ensureSwitchRuntime();
+    m_primaryScreen = new QSwitchScreen;
+    QWindowSystemInterface::handleScreenAdded(m_primaryScreen);
+}
+
+QNxSwitchIntegration::~QNxSwitchIntegration()
+{
+    if (m_primaryScreen)
+        QWindowSystemInterface::handleScreenRemoved(m_primaryScreen);
+    shutdownSwitchRuntime();
+}
+
+bool QNxSwitchIntegration::hasCapability(Capability cap) const
+{
+    switch (cap) {
+    case ThreadedPixmaps:
+    case RasterGLSurface:
+    case OpenGL:
+        return false;
+    case MultipleWindows:
+        return true;
+    default:
+        return QPlatformIntegration::hasCapability(cap);
+    }
+}
+
+QAbstractEventDispatcher *QNxSwitchIntegration::createEventDispatcher() const
+{
+    return createUnixEventDispatcher();
+}
+
+QPlatformWindow *QNxSwitchIntegration::createPlatformWindow(QWindow *window) const
+{
+    return new QSwitchPlatformWindow(window);
+}
+
+QPlatformBackingStore *QNxSwitchIntegration::createPlatformBackingStore(QWindow *window) const
+{
+    return new QSwitchBackingStore(window);
+}
+
+QPlatformNativeInterface *QNxSwitchIntegration::nativeInterface() const
+{
+    if (!m_nativeInterface)
+        m_nativeInterface.reset(new QPlatformNativeInterface);
+    return m_nativeInterface.get();
+}
+
+QNxSwitchIntegration *QNxSwitchIntegration::instance()
+{
+    return static_cast<QNxSwitchIntegration *>(QGuiApplicationPrivate::platformIntegration());
+}
