diff --git a/src/corelib/kernel/qcore_switch.cpp b/src/corelib/kernel/qcore_switch.cpp
new file mode 100644
index 00000000..f27c364d
--- /dev/null
+++ b/src/corelib/kernel/qcore_switch.cpp
@@ -0,0 +1,122 @@
+#include <errno.h>
+#include <fcntl.h>
+#include <grp.h>
+#include <pwd.h>
+#include <stddef.h>
+#include <string.h>
+#include <sys/socket.h>
+#include <sys/stat.h>
+#include <sys/types.h>
+#include <time.h>
+#include <unistd.h>
+
+extern "C" {
+
+uid_t getuid(void)
+{
+    return 0;
+}
+
+uid_t geteuid(void)
+{
+    return 0;
+}
+
+int getpagesize(void)
+{
+    return 4096;
+}
+
+long sysconf(int name)
+{
+    switch (name) {
+#if defined(_SC_PAGESIZE)
+    case _SC_PAGESIZE:
+        return 4096;
+#elif defined(_SC_PAGE_SIZE)
+    case _SC_PAGE_SIZE:
+        return 4096;
+#endif
+#ifdef _SC_NPROCESSORS_ONLN
+    case _SC_NPROCESSORS_ONLN:
+        return 4;
+#endif
+#ifdef _SC_OPEN_MAX
+    case _SC_OPEN_MAX:
+        return 256;
+#endif
+    default:
+        errno = EINVAL;
+        return -1;
+    }
+}
+
+int pipe(int fildes[2])
+{
+    return socketpair(AF_UNIX, SOCK_STREAM, 0, fildes);
+}
+
+int flock(int fd, int operation)
+{
+    struct flock fl {};
+    fl.l_whence = SEEK_SET;
+    fl.l_start = 0;
+    fl.l_len = 0;
+
+    switch (operation & (LOCK_SH | LOCK_EX | LOCK_UN)) {
+    case LOCK_UN:
+        fl.l_type = F_UNLCK;
+        break;
+    case LOCK_EX:
+        fl.l_type = F_WRLCK;
+        break;
+    case LOCK_SH:
+        fl.l_type = F_RDLCK;
+        break;
+    default:
+        errno = EINVAL;
+        return -1;
+    }
+
+    return fcntl(fd, (operation & LOCK_NB) ? F_SETLK : F_SETLKW, &fl);
+}
+
+int futimens(int fd, const struct timespec times[2])
+{
+    (void)fd;
+    (void)times;
+    errno = ENOSYS;
+    return -1;
+}
+
+struct passwd *getpwuid(uid_t uid)
+{
+    static char name[] = "switch";
+    static char dir[] = "/";
+    static char shell[] = "";
+    static struct passwd pwd;
+
+    pwd.pw_name = name;
+    pwd.pw_passwd = (char *)"";
+    pwd.pw_uid = uid;
+    pwd.pw_gid = 0;
+    pwd.pw_gecos = name;
+    pwd.pw_dir = dir;
+    pwd.pw_shell = shell;
+    return &pwd;
+}
+
+struct group *getgrgid(gid_t gid)
+{
+    static char name[] = "switch";
+    static char *members[] = { name, nullptr };
+    static struct group grp;
+
+    grp.gr_name = name;
+    grp.gr_passwd = (char *)"";
+    grp.gr_gid = gid;
+    grp.gr_mem = members;
+    return &grp;
+}
+
+}
