diff --git a/mkspecs/devices/switch-aarch64-libnx-g++/qmake.conf b/mkspecs/devices/switch-aarch64-libnx-g++/qmake.conf
new file mode 100644
index 00000000..eb71f31c
--- /dev/null
+++ b/mkspecs/devices/switch-aarch64-libnx-g++/qmake.conf
@@ -0,0 +1,32 @@
+#
+# qmake configuration for Nintendo Switch homebrew via devkitPro/libnx.
+#
+
+include(../common/linux_device_pre.conf)
+
+QMAKE_CC = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-gcc
+QMAKE_CXX = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-g++
+QMAKE_LINK = $$QMAKE_CXX
+QMAKE_LINK_SHLIB = $$QMAKE_CXX
+QMAKE_AR = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-gcc-ar cqs
+QMAKE_OBJCOPY = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-objcopy
+QMAKE_STRIP = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-strip
+QMAKE_NM = $$(DEVKITPRO)/devkitA64/bin/aarch64-none-elf-nm -P
+
+QMAKE_CFLAGS += -march=armv8-a+crc+crypto -mtune=cortex-a57 -mtp=soft -fPIE -D__SWITCH__
+QMAKE_CXXFLAGS += $$QMAKE_CFLAGS -fno-exceptions
+QMAKE_LFLAGS += -specs=$$(DEVKITPRO)/libnx/switch.specs -march=armv8-a+crc+crypto -mtune=cortex-a57 -mtp=soft
+
+QMAKE_INCDIR += \
+    $$(DEVKITPRO)/libnx/include \
+    $$(DEVKITPRO)/portlibs/switch/include
+
+QMAKE_LIBDIR += \
+    $$(DEVKITPRO)/libnx/lib \
+    $$(DEVKITPRO)/portlibs/switch/lib
+
+QMAKE_LIBS += -lnx
+
+include(../common/linux_device_post.conf)
+
+load(qt_config)
