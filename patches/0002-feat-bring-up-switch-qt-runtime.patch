 QT_BEGIN_NAMESPACE
 
 using namespace Qt::StringLiterals;
@@ -527,8 +544,11 @@ void QCoreApplicationPrivate::createEventDispatcher()
     Q_Q(QCoreApplication);
     QThreadData *data = QThreadData::current();
     Q_ASSERT(!data->hasEventDispatcher());
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::createEventDispatcher: begin");
     eventDispatcher = data->createEventDispatcher();
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::createEventDispatcher: created");
     eventDispatcher->setParent(q);
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::createEventDispatcher: parent set");
 }
 
 void QCoreApplicationPrivate::eventDispatcherReady()
@@ -935,20 +955,28 @@ void Q_TRACE_INSTRUMENT(qtcore) QCoreApplicationPrivate::init()
     if (!eventDispatcher)
         createEventDispatcher();
     Q_ASSERT(eventDispatcher);
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: dispatcher ready");
 
     if (!eventDispatcher->parent()) {
+        qt_switch_trace_coreapp("QCoreApplicationPrivate::init: moveToThread");
         eventDispatcher->moveToThread(thisThreadData->thread.loadAcquire());
         eventDispatcher->setParent(q);
+        qt_switch_trace_coreapp("QCoreApplicationPrivate::init: parent set after move");
     }
 
     thisThreadData->eventDispatcher = eventDispatcher;
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: threadData dispatcher stored");
     eventDispatcherReady();
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: eventDispatcherReady done");
 #endif
 
     processCommandLineArguments();
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: processCommandLineArguments done");
 
     qt_call_pre_routines();
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: pre routines done");
     qt_startup_hook();
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: startup hook done");
 #ifndef QT_BOOTSTRAPPED
     QtPrivate::initBindingStatusThreadId();
     if (Q_UNLIKELY(qtHookData[QHooks::Startup]))
@@ -957,7 +985,10 @@ void Q_TRACE_INSTRUMENT(qtcore) QCoreApplicationPrivate::init()
 
 #ifndef QT_NO_QOBJECT
     is_app_running = true; // No longer starting up.
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: is_app_running true");
 #endif
+
+    qt_switch_trace_coreapp("QCoreApplicationPrivate::init: return");
