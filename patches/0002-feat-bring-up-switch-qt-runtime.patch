+public:
+    void populateFontDatabase() override
+    {
+        const QByteArray fontPath = switchFontPath();
+        const QByteArray fontData = loadSwitchFile(fontPath.constData());
+        if (fontData.isEmpty()) {
+            traceSwitch("QSwitchFontDatabase: no font file");
+            return;
+        }
+
+        const QStringList families = QFreeTypeFontDatabase::addTTFile(fontData, fontPath);
+        if (families.isEmpty()) {
+            traceSwitch("QSwitchFontDatabase: addTTFile failed");
+            return;
+        }
+
+        m_defaultFamilies = families;
+        for (const QString &family : families) {
+            QPlatformFontDatabase::registerAliasToFontFamily(family, QStringLiteral("Sans Serif"));
+            QPlatformFontDatabase::registerAliasToFontFamily(family, QStringLiteral("Sans"));
+            QPlatformFontDatabase::registerAliasToFontFamily(family, QStringLiteral("Helvetica"));
+        }
+
+        traceSwitch("QSwitchFontDatabase: loaded default font");
+    }
+
+    QFont defaultFont() const override
+    {
+        if (!m_defaultFamilies.isEmpty())
+            return QFont(m_defaultFamilies.constFirst());
+        return QFont(QStringLiteral("DejaVu Sans"));
+    }
+
+    QString resolveFontFamilyAlias(const QString &family) const override
+    {
+        if (!m_defaultFamilies.isEmpty()) {
+            if (family.compare(QStringLiteral("Sans Serif"), Qt::CaseInsensitive) == 0
+                || family.compare(QStringLiteral("Sans"), Qt::CaseInsensitive) == 0
+                || family.compare(QStringLiteral("Helvetica"), Qt::CaseInsensitive) == 0) {
+                return m_defaultFamilies.constFirst();
+            }
+        }
+        return QFreeTypeFontDatabase::resolveFontFamilyAlias(family);
+    }
+
+    QStringList fallbacksForFamily(const QString &family,
+                                   QFont::Style style,
+                                   QFont::StyleHint styleHint,
+                                   QChar::Script script) const override
+    {
+        QStringList result;
+        if (!m_defaultFamilies.isEmpty()) {
+            if (family.isEmpty()
+                || family.compare(QStringLiteral("Sans Serif"), Qt::CaseInsensitive) == 0
+                || family.compare(QStringLiteral("Sans"), Qt::CaseInsensitive) == 0
+                || family.compare(QStringLiteral("Helvetica"), Qt::CaseInsensitive) == 0) {
+                result += m_defaultFamilies;
+            }
+        }
+        result += QFreeTypeFontDatabase::fallbacksForFamily(family, style, styleHint, script);
+        result.removeDuplicates();
+        return result;
+    }
