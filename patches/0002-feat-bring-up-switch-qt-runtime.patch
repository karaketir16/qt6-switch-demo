@@ -86,6 +103,7 @@ static void initThreadPipeFD(int fd)
 
 bool QThreadPipe::init()
 {
+    qt_switch_trace("QThreadPipe::init: enter");
 #if defined(Q_OS_WASM)
     // do nothing.
 #elif defined(Q_OS_VXWORKS)
@@ -115,22 +133,40 @@ bool QThreadPipe::init()
     if (!UsingEventfd)
         ret = qt_safe_pipe(fds, O_NONBLOCK);
     if (ret == -1) {
+#if defined(Q_OS_SWITCH)
+        qt_switch_trace("QThreadPipe::init: enabling fallback wakeup");
+        usesFallbackWakeup = true;
+        fds[0] = -1;
+        fds[1] = -1;
+        return true;
+#else
+        qt_switch_trace("QThreadPipe::init: create pipe failed");
         perror("QThreadPipe: Unable to create pipe");
         return false;
+#endif
     }
 #endif
 
+    qt_switch_trace("QThreadPipe::init: success");
     return true;
 }
 
 pollfd QThreadPipe::prepare() const
 {
+#if defined(Q_OS_SWITCH)
+    if (usesFallbackWakeup)
+        return qt_make_pollfd(-1, 0);
+#endif
     return qt_make_pollfd(fds[0], POLLIN);
 }
 
 void QThreadPipe::wakeUp()
 {
     if ((wakeUps.fetchAndOrAcquire(1) & 1) == 0) {
+#if defined(Q_OS_SWITCH)
+        if (usesFallbackWakeup)
+            return;
+#endif
 #  ifdef EFD_CLOEXEC
         eventfd_write(fds[0], 1);
         return;
@@ -142,6 +178,12 @@ void QThreadPipe::wakeUp()
 
 int QThreadPipe::check(const pollfd &pfd)
 {
+#if defined(Q_OS_SWITCH)
+    if (usesFallbackWakeup) {
+        Q_UNUSED(pfd);
+        return wakeUps.fetchAndStoreOrdered(0) ? 1 : 0;
+    }
+#endif
     Q_ASSERT(pfd.fd == fds[0]);
 
     char c[16];
@@ -174,8 +216,10 @@ int QThreadPipe::check(const pollfd &pfd)
 
 QEventDispatcherUNIXPrivate::QEventDispatcherUNIXPrivate()
 {
+    qt_switch_trace("QEventDispatcherUNIXPrivate: ctor");
