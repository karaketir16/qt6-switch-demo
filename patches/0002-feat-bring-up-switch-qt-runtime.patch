     return state;
 }
 
+QByteArray loadSwitchFile(const char *path)
+{
+    QByteArray data;
+    if (FILE *fp = std::fopen(path, "rb")) {
+        std::fseek(fp, 0, SEEK_END);
+        const long size = std::ftell(fp);
+        std::rewind(fp);
+        if (size > 0) {
+            data.resize(size);
+            const size_t bytesRead = std::fread(data.data(), 1, data.size(), fp);
+            if (bytesRead != size_t(data.size()))
+                data.clear();
+        }
+        std::fclose(fp);
+    }
+    return data;
+}
+
+QByteArray switchFontPath()
+{
+    const QByteArray configured = qgetenv("QT_SWITCH_FONTFILE");
+    if (!configured.isEmpty())
+        return configured;
