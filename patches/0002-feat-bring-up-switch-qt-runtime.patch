 }
 
 void QEventDispatcherUNIXPrivate::markPendingSocketNotifiers()
@@ -285,6 +334,9 @@ void QEventDispatcherUNIX::registerTimer(Qt::TimerId timerId, Duration interval,
 #endif
 
     Q_D(QEventDispatcherUNIX);
+#if defined(Q_OS_SWITCH)
