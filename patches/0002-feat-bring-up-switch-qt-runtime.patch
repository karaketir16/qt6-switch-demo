diff --git a/src/corelib/kernel/qcore_unix_p.h b/src/corelib/kernel/qcore_unix_p.h
index fd834cb2..6b8946cb 100644
--- a/src/corelib/kernel/qcore_unix_p.h
+++ b/src/corelib/kernel/qcore_unix_p.h
@@ -227,7 +227,7 @@ static inline int qt_safe_pipe(int pipefd[2], int flags = 0)
 {
     Q_ASSERT((flags & ~O_NONBLOCK) == 0);
 
-#ifdef QT_THREADSAFE_CLOEXEC
+#if defined(QT_THREADSAFE_CLOEXEC) && !defined(Q_OS_SWITCH)
     // use pipe2
     flags |= O_CLOEXEC;
     return ::pipe2(pipefd, flags); // pipe2 is documented not to return EINTR
diff --git a/src/corelib/kernel/qcoreapplication.cpp b/src/corelib/kernel/qcoreapplication.cpp
