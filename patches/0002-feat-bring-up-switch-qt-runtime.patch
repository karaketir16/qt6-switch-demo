@@ -410,6 +462,13 @@ bool QEventDispatcherUNIX::processEvents(QEventLoop::ProcessEventsFlags flags)
 {
     Q_D(QEventDispatcherUNIX);
     d->interrupt.storeRelaxed(0);
+#if defined(Q_OS_SWITCH)
+    static bool tracedFirstProcessEvents = false;
+    if (!tracedFirstProcessEvents) {
+        qt_switch_trace("QEventDispatcherUNIX::processEvents: first call");
+        tracedFirstProcessEvents = true;
+    }
+#endif
 
     // we are awake, broadcast it
     emit awake();
@@ -432,9 +491,19 @@ bool QEventDispatcherUNIX::processEvents(QEventLoop::ProcessEventsFlags flags)
         return false;
 
     QDeadlineTimer deadline;
+    std::optional<nanoseconds> switchTimerRemaining;
     if (canWait) {
         if (include_timers) {
             std::optional<nanoseconds> remaining = d->timerList.timerWait();
+            switchTimerRemaining = remaining;
+#if defined(Q_OS_SWITCH)
+            static bool tracedTimerWait = false;
+            if (!tracedTimerWait) {
+                qt_switch_trace(remaining ? "QEventDispatcherUNIX::processEvents: timerWait has deadline"
+                                           : "QEventDispatcherUNIX::processEvents: timerWait forever");
+                tracedTimerWait = true;
+            }
+#endif
             deadline = remaining ? QDeadlineTimer{*remaining}
                              : QDeadlineTimer(QDeadlineTimer::Forever);
         } else {
@@ -456,7 +525,42 @@ bool QEventDispatcherUNIX::processEvents(QEventLoop::ProcessEventsFlags flags)
     d->pollfds.append(d->threadPipe.prepare());
 
     int nevents = 0;
-    switch (qt_safe_poll(d->pollfds.data(), d->pollfds.size(), deadline)) {
+    int pollResult = 0;
+#if defined(Q_OS_SWITCH)
+    if (d->threadPipe.usesFallbackWakeup && d->socketNotifiers.isEmpty()) {
+        if (canWait) {
+            qint64 remainingNs = deadline.remainingTimeNSecs();
+            if (switchTimerRemaining) {
+                remainingNs = std::chrono::duration_cast<std::chrono::nanoseconds>(*switchTimerRemaining).count();
+                static bool tracedTimerRemaining = false;
+                if (!tracedTimerRemaining) {
+                    qt_switch_trace("QEventDispatcherUNIX::processEvents: using switch timer fallback wait");
+                    tracedTimerRemaining = true;
+                }
+            }
+            if (remainingNs > 0 && !deadline.isForever()) {
+                // Cap the sleep so timer handling can make forward progress even if
+                // deadline conversion behaves oddly under the emulator.
+                constexpr qint64 maxSleepNs = 20 * 1000 * 1000;
+                if (remainingNs > maxSleepNs)
+                    remainingNs = maxSleepNs;
+                const timespec ts {
+                    .tv_sec = static_cast<time_t>(remainingNs / 1000000000LL),
+                    .tv_nsec = static_cast<long>(remainingNs % 1000000000LL)
+                };
+                nanosleep(&ts, nullptr);
+            } else if (deadline.isForever()) {
+                static constexpr timespec ts { 0, 1000000L * 10 };
+                nanosleep(&ts, nullptr);
+            }
+        }
+    } else
+#endif
+    {
+        pollResult = qt_safe_poll(d->pollfds.data(), d->pollfds.size(), deadline);
+    }
+
+    switch (pollResult) {
     case -1:
         qErrnoWarning("qt_safe_poll");
         if (QT_CONFIG(poll_exit_on_error))
@@ -471,6 +575,11 @@ bool QEventDispatcherUNIX::processEvents(QEventLoop::ProcessEventsFlags flags)
         break;
     }
 
+#if defined(Q_OS_SWITCH)
+    if (d->threadPipe.usesFallbackWakeup)
+        nevents += d->threadPipe.check(pollfd { -1, 0, 0 });
+#endif
+
     if (include_timers)
         nevents += d->activateTimers();
 
